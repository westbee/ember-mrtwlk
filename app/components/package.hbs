{{#each @model.packages as |package|}}
  <div class="col-md-6 col-xl-5">
    <div class="package__box">
      <h5 class="box__headline">{{package.name}}</h5>
      {{#if package.teaser}}
        <p class="box__teaser">{{package.teaser}}</p>
      {{/if}}
      <div class="box__points">
        {{#each package.details as |detail|}}
          <p>&mdash; {{{detail}}}</p>
        {{/each}}
        <p class="box__extra">*{{package.extra}}</p>
      </div>
      <h5>
        &mdash;
        {{{package.price}}}
        &mdash;
        <br />
        <span class="box__tax">
          {{#if package.priceExtra}}{{package.priceExtra}} /{{/if}}
          inkl. MwSt.
        </span>
      </h5>

      {{#if package.investition}}
        <p class="box__investition-text">oder</p>
        <h5>
          &mdash;
          {{{package.investition.price}}}
          &mdash;
          <br />
          <span class="box__tax">
            {{package.investition.text}}
            / inkl. MwSt.
          </span>
        </h5>
      {{/if}}
    </div>
  </div>
{{/each}}
{{yield}}