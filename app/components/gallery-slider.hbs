{{#each @gallery.pics as |pic|}}
  <div class="card">
    {{#if @gallery.picurl}}
      <img
        src="/{{@gallery.url}}/{{@gallery.picurl}}_{{pic}}.jpg"
        class="img-fluid"
      />
    {{else}}
      <img src="/{{@gallery.url}}/{{pic}}.jpg" class="img-fluid" />
    {{/if}}
  </div>
{{/each}}