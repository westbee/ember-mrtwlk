<BsNavbar
  class="bg-transparent bg-top {{if isScrolling 'changeBg'}}"
  @type="light"
  @toggleBreakpoint="md"
  @collapsed={{true}}
  as |navbar|
>
  <div class="navbar-header">
    <navbar.toggle />
    <img
      src="/img/brand_logo.png"
      alt="Marta Wilk - Fotografin"
      class="brand-logo"
    />
  </div>
  <navbar.content class="justify-content-end">
    <navbar.nav as |nav|>
      <nav.item>
        <nav.linkTo @route="index">Home</nav.linkTo>
      </nav.item>
      <nav.item>
        <nav.linkTo @route="fotografin">Über mich</nav.linkTo>
      </nav.item>
      <nav.dropdown as |dd|>
        <dd.toggle>Bildergalerie <span class="caret"></span></dd.toggle>
        <dd.menu as |ddm|>
          {{#each @gallery as |gallery|}}
            <ddm.item><ddm.linkTo
                @route="bildergalerie.gallery"
                @model={{gallery}}
                class="nav-link"
                {{on "click" navbar.collapse}}
              >
              {{#unless (eq gallery.id 'fotoprojekte')}}
                {{gallery.name}}
              {{else}}
                Fotoprojekte
              {{/unless}}
              </ddm.linkTo></ddm.item>
          {{/each}}
        </dd.menu>
      </nav.dropdown>
      <nav.dropdown as |dd|>
        <dd.toggle>Pakete & Preise <span class="caret"></span></dd.toggle>
        <dd.menu as |ddm|>
          <ddm.item><ddm.linkTo
              {{on "click" navbar.collapse}}
              @route="pakete.babybauch"
              class="nav-link"
            >Babybauch</ddm.linkTo></ddm.item>
          <ddm.item><ddm.linkTo
              {{on "click" navbar.collapse}}
              @route="pakete.neugeborene"
              class="nav-link"
            >Neugeborene</ddm.linkTo></ddm.item>
          <ddm.item><ddm.linkTo
              {{on "click" navbar.collapse}}
              @route="pakete.embrace-yourself"
              class="nav-link"
            >Embrace Yourself</ddm.linkTo></ddm.item>
          <ddm.item><ddm.linkTo
              {{on "click" navbar.collapse}}
              @route="pakete.kinder-und-familien"
              class="nav-link"
            >Kinder & Familien</ddm.linkTo></ddm.item>
        </dd.menu>
      </nav.dropdown>
      <nav.item>
        <nav.linkTo @route="kontakt">Kontakt & Buchung</nav.linkTo>
      </nav.item>
    </navbar.nav>
  </navbar.content>
</BsNavbar>